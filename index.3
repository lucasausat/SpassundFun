
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Spaß & Fun Projekt</title>
    <style>
        body {
            font-family: 'Comic Sans MS', cursive, sans-serif; /* Für den extra Fun-Faktor */
            background-color: #f0f0f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            text-align: center;
        }

        h1 {
            color: #ff4757;
            text-shadow: 2px 2px #ffcc00;
        }

        .container {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 5px dashed #2ed573;
        }

        #runAwayBtn {
            padding: 15px 30px;
            font-size: 20px;
            font-weight: bold;
            background-color: #ff4757;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            position: absolute; /* Wichtig für das Bewegen */
            transition: all 0.1s ease;
            box-shadow: 0 5px #c0392b;
        }

        #runAwayBtn:active {
            box-shadow: 0 2px #c0392b;
            transform: translateY(3px);
        }

        #counterDisplay {
            margin-top: 20px;
            font-size: 1.2rem;
            color: #333;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Willkommen bei Spaß & Fun! 🎈</h1>
        <p>Versuch doch mal, den Button zu klicken...</p>
        <div id="counterDisplay">Erfolge: <span id="count">0</span></div>
    </div>

    <button id="runAwayBtn">Klick mich!</button>

    <script>
        const btn = document.getElementById('runAwayBtn');
        const countSpan = document.getElementById('count');
        let clicks = 0;

        // Funktion: Button springt an eine zufällige Position
        function moveButton() {
            const maxX = window.innerWidth - btn.clientWidth;
            const maxY = window.innerHeight - btn.clientHeight;

            const randomX = Math.floor(Math.random() * maxX);
            const randomY = Math.floor(Math.random() * maxY);

            btn.style.left = randomX + 'px';
            btn.style.top = randomY + 'px';
        }

        // Wenn die Maus den Button berührt -> Weglaufen!
        btn.addEventListener('mouseover', moveButton);

        // Falls es doch jemand schafft zu klicken
        btn.addEventListener('click', () => {
            clicks++;
            countSpan.innerText = clicks;
            alert("WAS?! Wie hast du das geschafft? 😱");
            moveButton(); // Und wieder weg!
        });

        // Initialposition setzen
        moveButton();
    </script>
</body>
</html>